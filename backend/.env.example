# Copy to `.env` and adjust for your environment.

# Database (SQLite file relative to the backend/ directory).
DATABASE_URL=sqlite:///./signal_clone.db

# Auth (mocked). Change JWT_SECRET in production.
JWT_SECRET=dev-secret-change-me-in-production
MOCK_OTP=123456

# Seed demo data on startup if the DB is empty (no-op once data exists).
SEED_ON_STARTUP=true

# CORS: comma-separated exact origins, plus an optional regex for previews.
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
